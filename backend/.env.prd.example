# Prod client env. Copy to `.env.prd`, fill real values, and rsync to the
# server (see CLAUDE.md §8). Loaded at runtime via docker-compose `env_file`.
# NODE_ENV/PORT/HOST are set by compose `environment:`, optional here.

# SQL Server (one multi-tenant DB — CompId/BranchId scope inside the app)
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Auth
JWT_SECRET=
JWT_EXPIRE=7d
